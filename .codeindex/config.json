{
  "languages": [
    "typescript",
    "python",
    "rust",
    "go"
  ],
  "embedding": {
    "provider": "local",
    "model": null
  },
  "summary": {
    "enabled": false,
    "provider": "anthropic",
    "model": "claude-haiku-4-5-20251001",
    "api_key_env": "ANTHROPIC_API_KEY",
    "batch_size": 20,
    "interval_seconds": 30
  },
  "query": {
    "default_top": 5,
    "default_depth": 1,
    "enhance": false
  },
  "daemon": {
    "debounce_ms": 500,
    "max_concurrent_embeds": 4,
    "respect_gitignore": true,
    "extra_ignore": []
  },
  "index": {
    "path": ".codeindex",
    "git_hooks": false
  }
}
{
  "name": "@hemsoft/buddy",
  "private": true,
  "version": "0.1.740",
  "description": "Your universal productivity companion - manage skills, tasks, and workflows",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "bun run bump && tsc && vite build && electron-builder",
    "bump": "bun scripts/bump-revision.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:quality": "bun scripts/lint-quality.ts",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "e18e": "npx --yes @e18e/cli analyze",
    "e18e:migrate": "npx --yes @e18e/cli migrate --all",
    "deps:check": "depcruise src electron --config .dependency-cruiser.cjs",
    "coverage:ratchet": "bun scripts/coverage-ratchet.ts",
    "bundle-size": "bun scripts/bundle-size.ts",
    "bundle-size:update": "bun scripts/bundle-size.ts --update",
    "preview": "vite preview",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:codegen": "convex codegen",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "productivity",
    "automation",
    "skills",
    "companion"
  ],
  "author": "HemSoft Developments",
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^0.2.2",
    "@octokit/graphql": "^9.0.3",
    "@octokit/plugin-retry": "^8.0.3",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.215.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.215.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.215.0",
    "@opentelemetry/instrumentation-dns": "^0.57.0",
    "@opentelemetry/instrumentation-http": "^0.215.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@uiw/react-markdown-preview": "^5.1.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "allotment": "^1.20.5",
    "convex": "1.35.1",
    "cron-parser": "^5.5.0",
    "electron-store": "^11.0.2",
    "electron-window-state": "^5.0.3",
    "lucide-react": "^0.563.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-gemoji": "^8.0.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^6.3.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.0",
    "dependency-cruiser": "^17.3.10",
    "electron": "^41.2.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "knip": "^6.0.5",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.22.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.0",
    "vscode-jsonrpc": "^8.2.0"
  },
  "optionalDependencies": {
    "@github/copilot-darwin-arm64": "^0.0.406",
    "@github/copilot-darwin-x64": "^0.0.406",
    "@github/copilot-win32-x64": "^0.0.406"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.2.0",
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings 0 --no-ignore"
    ],
    "*.{js,json,css}": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2"
    ]
  }
}

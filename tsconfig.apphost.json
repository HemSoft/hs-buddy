{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "vscode-jsonrpc/node.js": ["./node_modules/vscode-jsonrpc/lib/node/main.d.ts"]
    },
    "outDir": "./dist/apphost",
    "rootDir": "."
  },
  "include": ["apphost.ts", ".modules/**/*.ts"],
  "exclude": ["node_modules"]
}

{
  "display_information": {
    "name": "Relias Assistant",
    "description": "Relias Slack Assistant",
    "background_color": "#2e3033",
    "long_description": "Relias Assistant is an AI-powered chatbot designed to enhance productivity. Built initially for engineering teams, this bot serves as a virtual assistant that integrates seamlessly into daily communication, providing actionable insights, automating repetitive tasks, and accessing company-specific information to support decision-making."
  },
  "features": {
    "bot_user": {
      "display_name": "Relias Assistant",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/ra",
        "description": "Interact with Relias Assistant",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "assistant:write",
        "channels:history",
        "channels:read",
        "chat:write",
        "commands",
        "groups:history",
        "groups:read",
        "im:history",
        "incoming-webhook",
        "usergroups:read",
        "im:read",
        "users:read",
        "users.profile:read",
        "team:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": ["app_mention", "message.channels", "message.groups", "message.im"]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}

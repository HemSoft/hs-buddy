# Auto-bump revision and update CHANGELOG
bun scripts/bump-revision.ts
git add package.json src/components/AboutModal.tsx src/components/WelcomePanel.tsx src/components/TitleBar.tsx CHANGELOG.md

# Lint staged files
npx lint-staged

# Block commits on markdownlint violations for staged .md files
if [ -f ".git/hooks/pre-commit-markdown.ps1" ]; then
	pwsh -NoProfile -ExecutionPolicy Bypass -File ".git/hooks/pre-commit-markdown.ps1"
else
	echo "Missing .git/hooks/pre-commit-markdown.ps1. Reinstall copilot hooks."
	exit 1
fi

# Block commits when tests fail or coverage drops below threshold
bun run test:coverage

# Ratchet coverage thresholds up (never down) and include in commit
bun run coverage:ratchet
git add vitest.config.ts

# Block commits when the repo has TypeScript errors
bun run typecheck

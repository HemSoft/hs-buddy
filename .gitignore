# Dependencies
node_modules/
bun.lock
package-lock.json
yarn.lock

# Aspire generated SDK (regenerate with: aspire restore)
.modules/

# Build outputs (created by `bun run build` or `npm run build`)
dist/
dist-electron/

# Test coverage
coverage/
release/
*.local

# Environment
.env
.env.local
.env.*.local

# Logs
*.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Electron
out/
.tmp/

# Prompt checkpoints (local state, not tracked)
.github/prompts/.status-checkpoint

# Local debug helpers
_cdp.cjs
.playwright-mcp/
bench-output.txt

# Ralph loop logs (root only — scripts/ralph* should be tracked)
/ralph*.log

# Never ignore anything in scripts/ (overrides *.log* etc.)
!scripts/**

# Per-developer hooks settings (audio toggle, etc.)
.github/hooks/hooks-settings.json

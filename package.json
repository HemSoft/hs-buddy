{
  "name": "@hemsoft/buddy",
  "private": true,
  "version": "0.1.555",
  "description": "Your universal productivity companion - manage skills, tasks, and workflows",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "bun run bump && tsc && vite build && electron-builder",
    "bump": "bun scripts/bump-revision.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "e18e": "npx --yes @e18e/cli analyze",
    "e18e:migrate": "npx --yes @e18e/cli migrate --all",
    "coverage:ratchet": "bun scripts/coverage-ratchet.ts",
    "bundle-size": "bun scripts/bundle-size.ts",
    "bundle-size:update": "bun scripts/bundle-size.ts --update",
    "preview": "vite preview",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:codegen": "convex codegen",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "productivity",
    "automation",
    "skills",
    "companion"
  ],
  "author": "HemSoft Developments",
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^0.1.23",
    "@github/copilot-win32-x64": "^0.0.406",
    "@octokit/graphql": "^9.0.3",
    "@octokit/plugin-retry": "^8.0.3",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@uiw/react-markdown-preview": "^5.1.5",
    "allotment": "^1.20.5",
    "convex": "^1.31.7",
    "cron-parser": "^5.5.0",
    "electron-store": "^11.0.2",
    "electron-window-state": "^5.0.3",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^6.3.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "knip": "^6.0.5",
    "lint-staged": "^16.2.7",
    "markdownlint-cli2": "^0.20.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.2.0",
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings 0 --no-ignore"
    ],
    "*.{js,json,css}": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2"
    ]
  }
}

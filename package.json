{
  "name": "@hemsoft/buddy",
  "private": true,
  "version": "0.1.877",
  "description": "Your universal productivity companion - manage skills, tasks, and workflows",
  "type": "module",
  "main": "dist-electron/main.js",
  "files": [
    "dist",
    "dist-electron/main.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "bun run bump && tsc && vite build && electron-builder",
    "bump": "bun scripts/bump-revision.ts",
    "lint": "eslint . --max-warnings 0",
    "lint:quality": "bun scripts/lint-quality.ts",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "format": "prettier --write \"{src,shared}/**/*.{ts,tsx,js,json,css}\"",
    "format:check": "prettier --check \"{src,shared}/**/*.{ts,tsx,js,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run --reporter=verbose -t \"no accessibility violations\"",
    "test:coverage": "vitest run --coverage",
    "test:electron": "vitest run --config vitest.electron.config.ts",
    "test:electron:coverage": "vitest run --config vitest.electron.config.ts --coverage",
    "test:convex": "vitest run --config vitest.convex.config.ts",
    "test:convex:coverage": "vitest run --config vitest.convex.config.ts --coverage",
    "lhci": "lhci autorun",
    "bench": "vitest bench",
    "bench:json": "vitest bench --outputJson bench-results.json",
    "bench:median": "bun scripts/bench-median.ts",
    "bench:compare": "bun scripts/bench-compare.ts",
    "bench:update": "bun run bench:json && bun scripts/bench-compare.ts --update",
    "perf:memory": "bun perf/memory-monitor.ts",
    "perf:startup": "bun perf/run-startup.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.scripts.json && tsc --noEmit -p tsconfig.convex.json && tsc --noEmit -p tsconfig.apphost.json",
    "knip": "knip",
    "e18e": "bun scripts/run-e18e.ts",
    "e18e:migrate": "npx --yes @e18e/cli migrate --all",
    "deps:check": "depcruise src electron convex shared --config .dependency-cruiser.cjs",
    "security:electron": "bun scripts/check-electron-security.ts",
    "coverage:perfection": "bun scripts/coverage-perfection.ts",
    "coverage:perfection:strict": "bun scripts/coverage-perfection.ts --strict",
    "coverage:ratchet": "bun scripts/coverage-ratchet.ts",
    "coverage:ratchet:electron": "bun scripts/coverage-ratchet.ts --config vitest.electron.config.ts --summary coverage-electron/coverage-summary.json",
    "bundle-size": "bun scripts/bundle-size.ts",
    "bundle-size:update": "bun scripts/bundle-size.ts --update",
    "preview": "vite preview",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "convex:codegen": "convex codegen",
    "test:e2e": "npx playwright test --project=browser-e2e",
    "test:e2e:install": "npx playwright install chrome",
    "test:ipc-contracts": "vitest run src/ipc/contracts.test.ts src/ipc/contracts.registration.test.ts",
    "prepare": "husky"
  },
  "keywords": [
    "electron",
    "productivity",
    "automation",
    "skills",
    "companion"
  ],
  "author": "HemSoft Developments",
  "license": "MIT",
  "dependencies": {
    "@github/copilot-sdk": "^1.0.5",
    "@octokit/graphql": "^9.0.3",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "0.220.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/instrumentation-dns": "^0.63.0",
    "@opentelemetry/instrumentation-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@uiw/react-markdown-preview": "^5.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "allotment": "^1.20.5",
    "convex": "1.42.1",
    "cron-parser": "^5.6.1",
    "electron-store": "^11.0.2",
    "electron-window-state": "^5.0.3",
    "lucide-react": "^1.23.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-gemoji": "^8.0.0",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^6.5.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint-react/eslint-plugin": "^5.10.3",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "convex-test": "0.0.53",
    "dependency-cruiser": "^17.4.3",
    "electron": "^42.6.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^70.0.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.22.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.9.4",
    "react-scan": "^0.5.7",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "8.1.3",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vitest": "4.1.10",
    "vitest-axe": "^0.1.0",
    "vscode-jsonrpc": "^9.0.1"
  },
  "optionalDependencies": {
    "@github/copilot-darwin-arm64": "^1.0.68",
    "@github/copilot-darwin-x64": "^1.0.68",
    "@github/copilot-win32-x64": "^1.0.68"
  },
  "overrides": {
    "@babel/core": "^7.29.1",
    "@grpc/grpc-js": "^1.14.4",
    "fast-uri": "^3.1.2",
    "form-data": "^4.0.6",
    "js-yaml": "^3.15.0",
    "linkify-it": "^5.0.1",
    "markdown-it": "^14.2.0",
    "protobufjs": "^7.5.8",
    "qs": "^6.15.2",
    "tar": "^7.5.16",
    "tmp": "^0.2.6",
    "undici": "^7.28.0",
    "uuid": "^11.1.1",
    "ws": "^8.20.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.7",
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings 0 --no-warn-ignored"
    ],
    "*.{js,json,css}": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2"
    ]
  }
}
